APP_NAME=weather-platform
APP_ENV=local
APP_VERSION=0.1.0
LOG_LEVEL=INFO
APP_SECRET_KEY=replace-with-a-long-random-secret-min-32-chars
DATABASE_URL=postgresql+psycopg2://weather:weather@db:5432/weather
ENABLE_DOCS=true
ENFORCE_HTTPS=false
ALLOWED_HOSTS=localhost,127.0.0.1
POSTGRES_DB=weather
POSTGRES_USER=weather
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_PORT=5432
POSTGRES_HOST=db
ALCHEMY_ECHO=false
